{
	"name": "spacetime",
	"displayName": "Spacetime - Automatic Workspace Time Tracking",
	"publisher": "NewMeta",
	"repository": {
		"type": "git",
		"url": "https://github.com/JoelBesada/spacetime"
	},
	"icon": "assets/Logo.png",
	"description": "Automatically track time spent in each VSCode workspace, with Copilot usage tracking.",
	"version": "2.0.0",
	"engines": {
		"vscode": "^1.85.0"
	},
	"categories": [
		"Other"
	],
	"license": "ISC",
	"main": "./out/extension.js",
	"contributes": {
		"commands": [
			{
				"command": "spacetime.viewStats",
				"title": "Spacetime: View Stats"
			}
		],
		"configuration": {
			"title": "Spacetime",
			"properties": {
				"spacetime.maxIdleMinutes": {
					"type": "number",
					"default": 5,
					"description": "Maximum minutes of inactivity before Spacetime stops counting time. Activity is detected via edits, cursor moves, and saves."
				}
			}
		}
	},
	"scripts": {
		"vscode:prepublish": "npm run compile",
		"copy-assets": "node -e \"require('fs').mkdirSync('media',{recursive:true});require('fs').copyFileSync('node_modules/chart.js/dist/chart.umd.js','media/chart.umd.js')\"",
		"compile": "npm run copy-assets && tsc -p ./",
		"watch": "npm run copy-assets && tsc -watch -p ./",
		"pretest": "npm run compile && npm run lint",
		"lint": "eslint src",
		"test": "node ./out/test/runTest.js"
	},
	"devDependencies": {
		"@types/mocha": "^10.0.10",
		"@types/node": "^18.0.0",
		"@types/vscode": "^1.75.0",
		"@vscode/test-electron": "^2.5.2",
		"chart.js": "^4.4.0",
		"eslint": "^9.39.4",
		"glob": "^13.0.6",
		"mocha": "^11.7.5",
		"typescript": "^5.3.0",
		"typescript-eslint": "^8.57.2"
	}
}
